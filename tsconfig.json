{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": [],

    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    // Tightening is staged, not flipped wholesale. Every web/src module is now
    // typed (no @ts-nocheck), dead-code-free (noUnusedLocals), and free of
    // implicit `any` (noImplicitAny) -- the ~390 untyped params in the legacy
    // views (strategy/setup/rebalance/shell/trade...) were given honest
    // data-model interfaces per-file rather than blanket `any` annotations.
    //
    // The remaining stage is full `strict` (strictNullChecks et al.): ~510
    // null-safety decisions. Enable it next now that the `any` noise is gone.
    "strict": false,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["web/**/*.ts"]
}
