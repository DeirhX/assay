{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": [],

    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    // Tightening is staged, not flipped wholesale. Every web/src module is now
    // typed (no @ts-nocheck) and dead-code-free, so noUnusedLocals is on. The
    // remaining two flags are large, genuinely-typed efforts -- NOT a quick pass:
    //   - noImplicitAny: ~390 errors, almost all untyped params in the legacy
    //     views (strategy/setup/rebalance/shell/trade...). Doing it honestly
    //     means authoring each view's data-model interfaces; annotating them all
    //     `any` would silence the compiler while adding zero safety. Tackle it
    //     per-file, the same way @ts-nocheck was peeled off in Phase A.
    //   - strict (strictNullChecks et al.): ~900 errors total -- another ~510
    //     null-safety decisions on top of the above. Enable once noImplicitAny
    //     lands so the null work isn't fighting `any` noise at the same time.
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["web/**/*.ts"]
}
