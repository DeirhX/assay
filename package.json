{
  "name": "rebalancing-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend toolchain for the local rebalancing research console. The Python server (tools/serve.py) still owns the API, jobs, and auth.",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:py": "mypy tools",
    "lint": "eslint web/src web/tests e2e",
    "check:all": "pwsh tools/check.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "happy-dom": "^20.11.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
