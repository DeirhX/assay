{
  "name": "rebalancing-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend toolchain for the local rebalancing research console. The Python server (tools/serve.py) still owns the API, jobs, and auth.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:py": "mypy tools",
    "lint": "eslint web/src",
    "check:all": "pwsh tools/check.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
