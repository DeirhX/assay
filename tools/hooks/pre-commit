#!/bin/sh
# Defense-in-depth guard against accidentally committing personal/financial data
# into the public code repo. Real data lives in the private `data` submodule.
#
# Enable with:  git config core.hooksPath tools/hooks
# Bypass once:  git commit --no-verify   (use only when you are certain)
#
# The actual blocked-filename / marker patterns live in leakcheck.sh so the exact
# same rules also run server-side in CI (.github/workflows/guard.yml) — a fresh
# clone that never ran `git config core.hooksPath` is still covered there.
exec "$(dirname "$0")/leakcheck.sh" staged
